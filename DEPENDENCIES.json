{
  "INSTALLATION_COMMANDS": {
    "all_at_once": "npm install tailwindcss postcss autoprefixer framer-motion aos react-scroll lucide-react @tsparticles/react @tsparticles/slim react-scroll-parallax",

    "individual": [
      "npm install tailwindcss postcss autoprefixer",
      "npm install framer-motion",
      "npm install aos",
      "npm install react-scroll",
      "npm install lucide-react",
      "npm install @tsparticles/react @tsparticles/slim",
      "npm install react-scroll-parallax"
    ]
  },

  "DEPENDENCIES_PURPOSE": {
    "tailwindcss": "Utility-first CSS framework for styling",
    "postcss": "CSS processor required by Tailwind",
    "autoprefixer": "Adds vendor prefixes automatically",
    "framer-motion": "Animation library for React",
    "aos": "Animate On Scroll library",
    "react-scroll": "Smooth scrolling for navigation",
    "lucide-react": "Beautiful icon library",
    "@tsparticles/react": "Particle effects engine",
    "@tsparticles/slim": "Slim version of tsparticles",
    "react-scroll-parallax": "Parallax scrolling effects"
  },

  "ALREADY_INSTALLED": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.1"
  },

  "FILES_CREATED": [
    "src/components/Navbar.jsx",
    "src/components/ScrollProgress.jsx",
    "src/components/Hero.jsx",
    "src/components/Stats.jsx",
    "src/components/About.jsx",
    "src/components/Menu.jsx",
    "src/components/Testimonials.jsx",
    "src/components/Location.jsx",
    "src/components/Footer.jsx",
    "src/components/WhatsAppButton.jsx",
    "tailwind.config.js",
    "postcss.config.js",
    "SETUP-GUIDE.md"
  ],

  "FILES_MODIFIED": ["src/App.jsx", "src/index.css"],

  "NEXT_STEPS": [
    "1. Run: npm install tailwindcss postcss autoprefixer framer-motion aos react-scroll lucide-react @tsparticles/react @tsparticles/slim react-scroll-parallax",
    "2. Run: npm run dev",
    "3. Open browser to http://localhost:5173",
    "4. Customize content, colors, and images",
    "5. Replace Unsplash image URLs with your own",
    "6. Update contact information and WhatsApp number",
    "7. Deploy to production"
  ]
}
